{
  "name": "@localflow/core",
  "version": "0.4.1",
  "engines": {
    "node": ">=20"
  },
  "description": "Local-first data analysis with AI — only metadata reaches the model (the metadata-first protocol); it generates deterministic code that runs locally on your data",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx bench/run.ts",
    "bench:report": "tsx bench/report.ts"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "mathjs": "^15.2.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vitest": "^4.1.8"
  }
}
